<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="cn.wyq.serverwebsocket.mapper.UserMapper">
    <resultMap id="User" type="cn.wyq.serverwebsocket.pojo.User">
        <id property="id" column="id"></id>
        <result property="userName" column="user_name"></result>
        <result property="password" column="password"></result>
        <result property="path" column="path"></result>
        <result property="role" column="role"></result>
    </resultMap>
    <resultMap id="UserResultMap" type="cn.wyq.serverwebsocket.pojo.entity.UserEntity">
        <id property="id" column="id" />
        <result property="userName" column="user_name" />
        <result property="password" column="password" />
        <result property="path" column="path" />
        <result property="role" column="role" />
    </resultMap>
    <select id="login" parameterType="cn.wyq.serverwebsocket.pojo.User" resultMap="User">
        select *
        from user
        where user_name = #{userName}
    </select>

    <select id="selectAllUsers" resultMap="UserResultMap">
        SELECT id, user_name, password, path, role
        FROM user
        <where>
            <if test="id!=null and id!=''">
                id = #{id}
            </if>
            <if test="userName!=null and userName!=''">
                user_name like concat('%',#{userName},'%')
            </if>
            <if test="role!=null and role!=''">
                role = #{role}
            </if>
        </where>
        ORDER BY id DESC
    </select>

    <delete id="deleteById">
        DELETE FROM user WHERE id = #{id}
    </delete>

    <update id="updateUser" parameterType="cn.wyq.serverwebsocket.pojo.entity.UserEntity">
        UPDATE user
        <set>
            <if test="userName != null and userName != ''">
                user_name = #{userName},
            </if>
            <if test="password != null and password != ''">
                password = #{password},
            </if>
            <if test="path != null">
                path = #{path},
            </if>
            <if test="role != null">
                role = #{role},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <select id="findByToken" resultMap="User">
        select *
        from user
        where token = #{token}
    </select>

    <select id="findById" resultMap="User">
        select *
        from user
        where id = #{id}
    </select>

    <insert id="register" useGeneratedKeys="true" keyProperty="id">
        insert into user (user_name, password, path, role)
        values (#{userName}, #{password}, #{path}, #{role})
    </insert>

    <select id="findByUsername" resultMap="User">
        select *
        from user
        where user_name = #{userName}
    </select>

    <select id="findAllUsers" resultMap="User">
        select *
        from user
    </select>
    <select id="getPath" resultType="java.lang.String">
        select path
        from user
        where user_name = #{username}
    </select>
    <select id="export" resultType="cn.wyq.serverwebsocket.pojo.entity.UserEntity">
        SELECT id, user_name, password, path, role
        FROM user
        <where>
            <if test="id!=null and id!=''">
                id = #{id}
            </if>
            <if test="userName!=null and userName!=''">
                user_name like concat('%',#{userName},'%')
            </if>
            <if test="role!=null and role!=''">
                role = #{role}
            </if>
        </where>
        ORDER BY id DESC
    </select>
    <select id="findAllUserIds" resultType="java.lang.Integer">
        select id from user;
    </select>


</mapper>