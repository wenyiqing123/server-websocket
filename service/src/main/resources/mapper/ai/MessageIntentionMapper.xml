<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="cn.wyq.serverwebsocket.mapper.MessageIntentionMapper">
    <insert id="insert" parameterType="cn.wyq.serverwebsocket.pojo.entity.MessageIntention">
        insert into message_intention (user_id,tag_name,original_prompt,create_time)
        values (#{userId},#{tagName},#{originalPrompt},#{createTime});
    </insert>
    <select id="selectAllOrderByTimeAsc" resultType="cn.wyq.serverwebsocket.pojo.entity.MessageIntention">
        select *
        from message_intention
        ORDER BY create_time ASC;
    </select>
    <select id="selectByTagNameAndOriginalPrompt"
            resultType="cn.wyq.serverwebsocket.pojo.entity.MessageIntention">
        select *
        from message_intention where tag_name=#{currentTag} and original_prompt=#{originalPrompt};
    </select>
</mapper>